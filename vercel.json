{
    "version": 2,
    "outputDirectory": "frontend/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/app/main.py"
        },
        {
            "source": "/(.*)",
            "destination": "/$1"
        }
    ],
    "functions": {
        "backend/app/main.py": {
            "runtime": "vercel-python@0.1.0"
        }
    }
}